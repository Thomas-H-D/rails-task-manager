<h1><%= @task.title %></h1>
<p><%= @task.details %></p>
<p><%= @task.completed ? "It is finished!" : "Still not done" %></p>
<%= link_to "Edit this Task", edit_task_path(@task) %>
<%= link_to "Delete Task", task_path(@task), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
<%= link_to "Back to Task List", tasks_path %>
